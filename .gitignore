# Python bytecode / build metadata
__pycache__/
*.py[cod]
*.egg-info/

# Incomplete downloads
*.part

# Built HF datasets (regenerable from analysis/*subset*.json)
/mvr_dataset/
/crossview_dataset/
*.tmp/
*.tmp

# Generated converter output: pre-subset master pools (regenerable via
# convert_crossview.py in <1s). The eval *subset* json files are tracked; these
# *_qa.json pools are not.
/analysis/crossview_*_qa.json

# AgiBot HF tar-tree cache (regenerated by fetch_agibot_videos.py)
/analysis/.agibot_tree_cache.json

# Large fetched media — licensed, do not commit
/crossview-release-annotations/crossview-release/videos/
# External CrossView dataset (downloaded annotations + manifests live alongside
# the gitignored videos; obtained from the upstream release, not tracked here)
/crossview-release-annotations/
# CVBench eval clips (downloaded, ~2GB)
/Video-R1/src/r1-v/Evaluation/CVBench/

# SLURM + fetch logs (kept on disk for provenance, not tracked)
/analysis/logs/
/analysis/download_subset.log

# Preserved backup / superseded runs
*.bak

# Regenerable presentation binary (rebuilt by analysis/make_slides.py)
/analysis/multicam_progress.pptx

# Claude Code runtime/config
.claude/
